generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Link {
  id          String   @id @default(uuid())
  url         String   @unique // The target URL
  title       String?  
  clicks      Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  events      ClickEvent[]
}

model ClickEvent {
  id          String   @id @default(uuid())
  linkId      String
  link        Link     @relation(fields: [linkId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  ipAddress   String?
  userAgent   String?
  country     String?
  city        String?
  region      String?
  referrer    String?
}
